{
  "name": "lazarus",
  "version": "0.1.0",
  "description": "Lightweight heartbeat failover for hybrid local/cloud operation. Your service, risen.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "lazarus": "./dist/index.js"
  },
  "homepage": "https://robysmiller.github.io/lazarus",
  "repository": {
    "type": "git",
    "url": "https://github.com/RobySMiller/lazarus.git"
  },
  "bugs": {
    "url": "https://github.com/RobySMiller/lazarus/issues"
  },
  "author": "Roby Miller",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "failover",
    "heartbeat",
    "high-availability",
    "deadman-switch",
    "uptime",
    "local-first",
    "ai-agent",
    "devops",
    "hybrid",
    "local-cloud"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "lazarus.example.yml",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "yaml": "^2.8.2"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^4.0.18"
  }
}
